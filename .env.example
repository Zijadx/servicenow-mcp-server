# ── ServiceNow Connection ─────────────────────────────────────────────────────

# ServiceNow instance URL (no trailing slash)
SN_INSTANCE=https://your-instance.service-now.com

# Service-account credentials used by the MCP server and Chat UI to talk to
# ServiceNow. The Chat UI's per-user login (Phase 3) is a separate concern and
# does NOT use these — see README.md "Authentication model".
SN_USER=your_username
SN_PASS=your_password

# ── MCP Server (server.py) ────────────────────────────────────────────────────

# Bearer token clients must send in Authorization: Bearer <token>
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=

# Port the MCP server listens on when MCP_TRANSPORT=streamable-http
MCP_PORT=8000

# Transport: "stdio" (default, for local MCP clients) or "streamable-http"
MCP_TRANSPORT=stdio

# ── Chat UI (ui_server.py) ────────────────────────────────────────────────────

# Secret used to sign the session cookie. REQUIRED for the UI to start.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Port the Chat UI listens on
UI_PORT=3000

# Set to 1 when serving the UI behind HTTPS — enables Secure cookie flag
UI_BEHIND_HTTPS=0

# ── Security Analyst Agent (security_analyst.py) ──────────────────────────────

# Anthropic API key (required for security_analyst.py)
ANTHROPIC_API_KEY=

# AbuseIPDB API key (optional — agent uses simulated data if not set)
# Get one free at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=
